#!/bin/sh
# SessionStart hook: auto-register MCP server, load archcore context, report staleness.
# Uses bin/archcore shim which resolves (and downloads on first use) the real CLI.

SCRIPT_DIR=$(dirname "$0")
# shellcheck source=lib/normalize-stdin.sh
. "$SCRIPT_DIR/lib/normalize-stdin.sh"

SHIM="$SCRIPT_DIR/archcore"
SHIM_ABS=$(CDPATH='' cd -- "$SCRIPT_DIR" && pwd)/archcore

# Emit informational context to the agent (structured for Claude Code/Copilot, plain for others).
_archcore_emit_info() {
  _msg="$1"
  case "$ARCHCORE_HOST" in
    claude-code|copilot)
      _escaped=$(printf '%s' "$_msg" | sed 's/\\/\\\\/g; s/"/\\"/g' | awk 'BEGIN{ORS="\\n"}{print}')
      printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}' "$_escaped"
      ;;
    *)
      printf '%s\n' "$_msg"
      ;;
  esac
}

# Auto-register MCP server in local scope if the Claude CLI is available and
# archcore is not yet registered. Local scope wins precedence over project
# .mcp.json, so this covers both the happy path (new install) and the edge case
# where a stale project .mcp.json points to a bare "archcore" command that
# isn't in PATH. Idempotent.
if command -v claude >/dev/null 2>&1; then
  if ! claude mcp list 2>/dev/null | grep -qi '^archcore'; then
    claude mcp add archcore "$SHIM_ABS" mcp -s local >/dev/null 2>&1 || true
  fi
fi

# Check if .archcore/ exists (not initialized)
if [ ! -d ".archcore" ]; then
  _archcore_emit_info "[Archcore] no .archcore/ directory in this project. Run 'archcore init' to initialize a knowledge base. Skills and agents need an initialized knowledge base. If the user asks for an Archcore operation, offer to run 'archcore init' first."
  exit 0
fi

# Run the host-specific session-start hook via shim.
# The shim downloads the CLI on first use; errors surface on stderr. A non-zero
# exit is non-fatal for the session — we still want staleness info to run.
printf '%s' "$ARCHCORE_RAW_STDIN" | "$SHIM" hooks "$ARCHCORE_HOST" session-start || true

# Run staleness check (code-document drift detection)
STALENESS=$("$SCRIPT_DIR/check-staleness" 2>/dev/null) || true
if [ -n "$STALENESS" ]; then
  echo ""
  echo "$STALENESS"
fi

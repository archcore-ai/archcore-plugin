#!/bin/sh
# SessionStart hook: load archcore context or warn if CLI is missing.
# Uses normalized stdin — works across Claude Code, Cursor, and other hosts.

SCRIPT_DIR=$(dirname "$0")
# shellcheck source=lib/normalize-stdin.sh
. "$SCRIPT_DIR/lib/normalize-stdin.sh"

# Check if archcore CLI is available
if ! command -v archcore >/dev/null 2>&1; then
  echo "[Archcore] CLI not found. Install: curl -fsSL https://archcore.ai/install.sh | bash"
  echo "Then initialize: archcore init"
  echo ""
  echo "Without the CLI, Archcore MCP tools are unavailable."
  echo "Skills (/archcore:*) and agents (archcore-assistant, archcore-auditor) will not function."
  exit 0
fi

# Check if .archcore/ exists (not initialized)
if [ ! -d ".archcore" ]; then
  echo "[Archcore] Not initialized in this project. Run: archcore init"
  echo ""
  echo "The CLI is installed but this project has no .archcore/ directory."
  echo "Skills and agents require an initialized Archcore knowledge base."
  exit 0
fi

# All good — run the host-specific session-start hook
# Pipe raw stdin through since archcore CLI parses it
printf '%s' "$ARCHCORE_RAW_STDIN" | archcore hooks "$ARCHCORE_HOST" session-start

# Run staleness check (code-document drift detection)
STALENESS=$("$SCRIPT_DIR/check-staleness" 2>/dev/null) || true
if [ -n "$STALENESS" ]; then
  echo ""
  echo "$STALENESS"
fi

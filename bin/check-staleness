#!/bin/sh
# SessionStart staleness check: detect code-document drift via git.
# Called from bin/session-start after context loading.
# Output: plain text warning (max 2KB) or empty. Always exits 0.

# Must be in a git repo
git rev-parse --git-dir >/dev/null 2>&1 || exit 0

# Find last commit that touched .archcore/
LAST_DOC_COMMIT=$(git log -1 --format=%H -- .archcore/ 2>/dev/null)
[ -z "$LAST_DOC_COMMIT" ] && exit 0

# Find source files changed since last doc update (exclude .archcore/ itself)
CHANGED=$(git diff --name-only "$LAST_DOC_COMMIT"..HEAD -- ':(exclude).archcore/' 2>/dev/null)
[ -z "$CHANGED" ] && exit 0

CHANGED_COUNT=$(printf '%s\n' "$CHANGED" | wc -l | tr -d ' ')

# Extract unique top-level directories from changed files (e.g., src/, lib/)
CHANGED_DIRS=$(printf '%s\n' "$CHANGED" | sed 's|/.*||' | sort -u)

# Search .archcore/ documents for references to changed directories
AFFECTED=""
AFFECTED_COUNT=0

for DIR in $CHANGED_DIRS; do
  # Count how many changed files are in this directory
  DIR_COUNT=$(printf '%s\n' "$CHANGED" | grep -c "^${DIR}/" 2>/dev/null || echo 0)
  [ "$DIR_COUNT" = "0" ] && continue

  # Find .archcore/ documents that mention this directory
  MATCHING_DOCS=$(grep -rl "${DIR}/" .archcore/ 2>/dev/null | grep '\.md$' | head -5)
  for DOC in $MATCHING_DOCS; do
    # Strip .archcore/ prefix for cleaner output
    DOC_SHORT=$(echo "$DOC" | sed 's|^\./||; s|^\.archcore/||')
    AFFECTED="${AFFECTED}  - ${DOC_SHORT} — references ${DIR}/ (${DIR_COUNT} files changed)
"
    AFFECTED_COUNT=$((AFFECTED_COUNT + 1))
  done
done

# Output warning
if [ "$AFFECTED_COUNT" -gt 0 ]; then
  printf '[Archcore Staleness] %s source files changed since last documentation update.\n' "$CHANGED_COUNT"
  printf 'Potentially affected documents:\n'
  printf '%s' "$AFFECTED" | head -10
  printf 'Run /archcore:actualize for detailed analysis.\n'
elif [ "$CHANGED_COUNT" -gt 5 ]; then
  printf '[Archcore Staleness] %s source files changed since last documentation update.\n' "$CHANGED_COUNT"
  printf 'Consider running /archcore:actualize to check for stale documentation.\n'
fi

exit 0
